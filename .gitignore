# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# database
/data
*.db
*.db-journal

# user-uploaded content — must stay out of source control
/public/auditions/*
!/public/auditions/.gitkeep
/public/members/*
!/public/members/.gitkeep

# editor / claude
/.claude

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local SQLite DB (legacy)
data/

# AI agent instructions — kept locally only, not in the public repo.
# Includes both repo-level (CLAUDE.md → AGENTS.md import) and the
# umbrella AGENTS.md spec.
AGENTS.md
CLAUDE.md
